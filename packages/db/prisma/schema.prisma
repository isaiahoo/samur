generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum UserRole {
  resident
  volunteer
  coordinator
  admin
}

enum IncidentType {
  flood
  mudslide
  landslide
  road_blocked
  building_damaged
  power_out
  water_contaminated
}

enum Severity {
  low
  medium
  high
  critical
}

enum IncidentStatus {
  unverified
  verified
  resolved
  false_report
}

enum HelpRequestType {
  need
  offer
}

enum HelpCategory {
  rescue
  shelter
  food
  water
  medicine
  equipment
  transport
  labor
  generator
  pump
}

enum Urgency {
  normal
  urgent
  critical
}

enum HelpRequestStatus {
  open
  claimed
  in_progress
  completed
  cancelled
}

enum HelpResponseStatus {
  responded
  on_way
  arrived
  helped
  cancelled
}

enum AlertUrgency {
  info
  warning
  critical
}

enum AlertSource {
  manual        // coordinator/admin composed via AlertComposer
  river         // auto from riverScraper: observed level crossed danger
  seismic       // auto from earthquakeClient: M5+ event
  ai_forecast   // auto from aiAlertGenerator: AI forecast peak crosses 75% of danger
  news          // reserved — not wired yet (Phase 5 context feed)
}

enum ShelterStatus {
  open
  full
  closed
}

enum RiverTrend {
  rising
  stable
  falling
}

enum Source {
  pwa
  telegram
  vk
  sms
  meshtastic
}

enum Channel {
  pwa
  telegram
  vk
  sms
  meshtastic
}

enum Amenity {
  food
  beds
  medical
  power
  wifi
}

// ─── Models ─────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  name      String?
  phone     String?  @unique
  role      UserRole @default(resident)
  vkId      String?  @unique @map("vk_id")
  tgId      String?  @unique @map("tg_id")
  password  String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  incidents         Incident[]    @relation("IncidentAuthor")
  verifiedIncidents Incident[]    @relation("IncidentVerifier")
  helpRequests      HelpRequest[] @relation("HelpRequestAuthor")
  claimedRequests   HelpRequest[] @relation("HelpRequestClaimer")
  helpResponses     HelpResponse[]
  helpMessages      HelpMessage[]
  helpMessageReads  HelpMessageRead[]
  helpMessageReports HelpMessageReport[] @relation("Reporter")
  helpMessageReportsResolved HelpMessageReport[] @relation("Resolver")
  alerts            Alert[]

  @@index([role])
  @@map("users")
}

model Incident {
  id          String         @id @default(cuid())
  userId      String?        @map("user_id")
  type        IncidentType
  severity    Severity
  lat         Float
  lng         Float
  location    Unsupported("geometry(Point, 4326)")?
  address     String?
  description String?
  photoUrls   String[]       @default([]) @map("photo_urls")
  status      IncidentStatus @default(unverified)
  verifiedBy  String?        @map("verified_by")
  source      Source         @default(pwa)
  version     Int            @default(0)
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  deletedAt   DateTime?      @map("deleted_at")

  author       User?         @relation("IncidentAuthor", fields: [userId], references: [id], onDelete: SetNull)
  verifier     User?         @relation("IncidentVerifier", fields: [verifiedBy], references: [id], onDelete: SetNull)
  helpRequests HelpRequest[]

  @@index([userId])
  @@index([verifiedBy])
  @@index([status, type])
  @@index([severity])
  @@index([createdAt])
  @@index([source])
  @@index([deletedAt])
  @@map("incidents")
}

model HelpRequest {
  id           String            @id @default(cuid())
  userId       String?           @map("user_id")
  incidentId   String?           @map("incident_id")
  type         HelpRequestType
  category     HelpCategory
  description  String?
  lat          Float
  lng          Float
  location     Unsupported("geometry(Point, 4326)")?
  address      String?
  urgency      Urgency           @default(normal)
  contactPhone String?           @map("contact_phone")
  contactName  String?           @map("contact_name")
  status       HelpRequestStatus @default(open)
  claimedBy    String?           @map("claimed_by")
  isSOS        Boolean           @default(false) @map("is_sos")
  situation    String?
  peopleCount  Int?              @map("people_count")
  photoUrls       String[]          @default([]) @map("photo_urls")
  batteryLevel    Int?              @map("battery_level")
  sourceIp        String?           @map("source_ip")
  confidenceScore Int?              @map("confidence_score")
  source          Source            @default(pwa)
  version      Int               @default(0)
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")
  deletedAt    DateTime?         @map("deleted_at")

  author       User?             @relation("HelpRequestAuthor", fields: [userId], references: [id], onDelete: SetNull)
  claimer      User?             @relation("HelpRequestClaimer", fields: [claimedBy], references: [id], onDelete: SetNull)
  incident     Incident?         @relation(fields: [incidentId], references: [id], onDelete: SetNull)
  responses    HelpResponse[]
  messages     HelpMessage[]
  messageReads HelpMessageRead[]

  @@index([userId])
  @@index([claimedBy])
  @@index([status, type])
  @@index([status, category])
  @@index([isSOS, status])
  @@index([urgency])
  @@index([createdAt])
  @@index([source])
  @@index([deletedAt])
  @@map("help_requests")
}

model HelpResponse {
  id            String             @id @default(cuid())
  helpRequestId String             @map("help_request_id")
  userId        String             @map("user_id")
  status        HelpResponseStatus @default(responded)
  note          String?
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")

  helpRequest HelpRequest @relation(fields: [helpRequestId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([helpRequestId, userId])
  @@index([helpRequestId, status])
  @@index([userId])
  @@map("help_responses")
}

model HelpMessage {
  id            String    @id @default(cuid())
  helpRequestId String    @map("help_request_id")
  authorId      String    @map("author_id")
  body          String    @db.Text
  /// Optional photo attachments (URLs from POST /uploads). Each message
  /// can carry up to 5 photos; API enforces at least one of body/photos
  /// is non-empty. Reuses the request-photo storage pipeline.
  photoUrls     String[]  @default([]) @map("photo_urls")
  createdAt     DateTime  @default(now()) @map("created_at")
  deletedAt     DateTime? @map("deleted_at")
  /// Who soft-deleted this message. NULL when it's a natural deletion
  /// (request teardown) or when the field was added post-hoc. Used for
  /// moderation audit.
  deletedBy     String?   @map("deleted_by")
  /// Why the message was deleted. Values:
  ///   "moderator_removed" — coordinator/admin via the admin queue or
  ///                         the direct DELETE endpoint
  ///   "author_removed"    — (reserved; self-delete is a future feature)
  deletedReason String?   @map("deleted_reason")

  helpRequest HelpRequest @relation(fields: [helpRequestId], references: [id], onDelete: Cascade)
  author      User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  reports     HelpMessageReport[]

  @@index([helpRequestId, createdAt])
  @@index([authorId])
  @@index([deletedAt])
  @@map("help_messages")
}

enum HelpMessageReportReason {
  abuse
  spam
  doxxing
  off_topic
  other
}

enum HelpMessageReportStatus {
  open
  resolved_delete
  resolved_dismiss
}

/// User-initiated report on an individual chat message. One report per
/// (message, reporter) — duplicate reports from the same user upsert
/// rather than create. Coordinators resolve via the admin queue, which
/// either soft-deletes the message (resolved_delete) or dismisses the
/// report (resolved_dismiss).
model HelpMessageReport {
  id          String                   @id @default(cuid())
  messageId   String                   @map("message_id")
  reporterId  String                   @map("reporter_id")
  reason      HelpMessageReportReason
  details     String?                  @db.VarChar(500)
  status      HelpMessageReportStatus  @default(open)
  resolvedBy  String?                  @map("resolved_by")
  resolvedAt  DateTime?                @map("resolved_at")
  createdAt   DateTime                 @default(now()) @map("created_at")

  message   HelpMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  reporter  User        @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  resolver  User?       @relation("Resolver", fields: [resolvedBy], references: [id], onDelete: SetNull)

  @@unique([messageId, reporterId])
  @@index([status, createdAt])
  @@index([reporterId])
  @@map("help_message_reports")
}

model HelpMessageRead {
  id            String   @id @default(cuid())
  helpRequestId String   @map("help_request_id")
  userId        String   @map("user_id")
  lastReadAt    DateTime @map("last_read_at")

  helpRequest HelpRequest @relation(fields: [helpRequestId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([helpRequestId, userId])
  @@index([userId])
  @@map("help_message_reads")
}

model Alert {
  id        String       @id @default(cuid())
  authorId  String       @map("author_id")
  urgency   AlertUrgency
  /// Which pipeline produced this alert. Drives the icon + label on the
  /// alert card and lets the feed be filtered by origin.
  source    AlertSource  @default(manual)
  title     String
  body      String
  geoBounds Unsupported("geometry(Polygon, 4326)")? @map("geo_bounds")
  channels  Channel[]
  sentAt    DateTime     @default(now()) @map("sent_at")
  expiresAt DateTime?    @map("expires_at")
  deletedAt DateTime?    @map("deleted_at")

  author        User              @relation(fields: [authorId], references: [id], onDelete: Cascade)
  smsBroadcasts SmsBroadcastLog[]

  @@index([authorId])
  @@index([urgency])
  @@index([source])
  @@index([sentAt])
  @@index([expiresAt])
  @@index([deletedAt])
  @@map("alerts")
}

model Shelter {
  id               String        @id @default(cuid())
  name             String
  lat              Float
  lng              Float
  location         Unsupported("geometry(Point, 4326)")?
  address          String
  capacity         Int
  currentOccupancy Int           @default(0) @map("current_occupancy")
  amenities        Amenity[]
  contactPhone     String?       @map("contact_phone")
  status           ShelterStatus @default(open)
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")
  deletedAt        DateTime?     @map("deleted_at")

  @@index([status])
  @@index([deletedAt])
  @@map("shelters")
}

model RiverLevel {
  id              String     @id @default(cuid())
  riverName       String     @map("river_name")
  stationName     String     @map("station_name")
  lat             Float
  lng             Float
  location        Unsupported("geometry(Point, 4326)")?
  levelCm         Float?     @map("level_cm")
  dangerLevelCm   Float?     @map("danger_level_cm")
  dischargeCubicM Float?     @map("discharge_cubic_m")
  dischargeMean   Float?     @map("discharge_mean")
  dischargeMax    Float?     @map("discharge_max")
  dischargeMedian Float?     @map("discharge_median")
  dischargeMin    Float?     @map("discharge_min")
  dischargeP25    Float?     @map("discharge_p25")
  dischargeP75    Float?     @map("discharge_p75")
  dischargeAnnualMean Float?  @map("discharge_annual_mean")
  dataSource      String?    @map("data_source")
  isForecast      Boolean    @default(false) @map("is_forecast")
  trend           RiverTrend
  predictionLower Float?     @map("prediction_lower")
  predictionUpper Float?     @map("prediction_upper")
  measuredAt      DateTime   @map("measured_at")
  createdAt       DateTime   @default(now()) @map("created_at")
  deletedAt       DateTime?  @map("deleted_at")

  @@unique([riverName, stationName, measuredAt])
  @@index([riverName, measuredAt])
  @@index([measuredAt])
  @@index([deletedAt])
  @@index([riverName, stationName, isForecast, measuredAt])
  @@map("river_levels")
}

model HistoricalRiverLevel {
  id          String   @id @default(cuid())
  riverName   String   @map("river_name")
  stationName String   @map("station_name")
  date        DateTime @db.Date
  valueCm     Float    @map("value_cm")
  source      String   @default("allrivers.info")
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([riverName, stationName, date])
  @@index([riverName, stationName, date])
  @@index([date])
  @@map("historical_river_levels")
}

model HistoricalRiverStats {
  id          String @id @default(cuid())
  riverName   String @map("river_name")
  stationName String @map("station_name")
  dayOfYear   Int    @map("day_of_year")
  avgCm       Float  @map("avg_cm")
  minCm       Float  @map("min_cm")
  maxCm       Float  @map("max_cm")
  p10Cm       Float  @map("p10_cm")
  p90Cm       Float  @map("p90_cm")
  sampleCount Int    @map("sample_count")

  @@unique([riverName, stationName, dayOfYear])
  @@index([riverName, stationName])
  @@map("historical_river_stats")
}

model ForecastSnapshot {
  id              String   @id @default(cuid())
  riverName       String   @map("river_name")
  stationName     String   @map("station_name")
  forecastMadeAt  DateTime @map("forecast_made_at") @db.Date
  targetDate      DateTime @map("target_date") @db.Date
  horizonDays     Int      @map("horizon_days")
  predictedCm     Float    @map("predicted_cm")
  predictionLower Float?   @map("prediction_lower")
  predictionUpper Float?   @map("prediction_upper")
  dataSource      String   @map("data_source")
  modelVersion    String?  @map("model_version")
  createdAt       DateTime @default(now()) @map("created_at")

  @@unique([riverName, stationName, forecastMadeAt, horizonDays])
  @@index([riverName, stationName, targetDate])
  @@index([targetDate])
  @@map("forecast_snapshots")
}

model MlModelMetrics {
  id          String   @id @default(cuid())
  modelName   String   @map("model_name")
  stationKey  String   @map("station_key")
  horizon     Int      @default(1)
  nse         Float
  kge         Float
  rmse        Float
  evaluatedAt DateTime @map("evaluated_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([modelName, stationKey])
  @@map("ml_model_metrics")
}

model SmsBroadcastLog {
  id      String   @id @default(cuid())
  alertId String   @map("alert_id")
  phone   String
  sentAt  DateTime @default(now()) @map("sent_at")

  alert Alert @relation(fields: [alertId], references: [id], onDelete: Cascade)

  @@unique([alertId, phone])
  @@index([alertId])
  @@map("sms_broadcast_log")
}

model ChannelHeartbeat {
  channel   String   @id
  lastSeen  DateTime @default(now()) @map("last_seen")
  metadata  Json?

  @@map("channel_heartbeats")
}

model Earthquake {
  id        String   @id @default(cuid())
  usgsId    String   @unique @map("usgs_id")
  magnitude Float
  depth     Float    // km
  lat       Float
  lng       Float
  place     String   // e.g. "15 km NW of Makhachkala"
  time      DateTime
  felt      Int?     // number of felt reports
  mmi       Float?   // estimated max Modified Mercalli Intensity
  source    String   @default("usgs") // "usgs" | "emsc"
  createdAt DateTime @default(now()) @map("created_at")

  @@index([time])
  @@index([magnitude])
  @@map("earthquakes")
}

model NewsArticle {
  id          String   @id @default(cuid())
  feedId      String   @map("feed_id")       // e.g. "mchs-dagestan-forecasts"
  externalId  String   @map("external_id")   // guid/link from RSS for dedup
  title       String
  summary     String?                        // cleaned excerpt
  body        String?                        // full content (if available)
  url         String                         // original article URL
  imageUrl    String?  @map("image_url")
  category    String?                        // from RSS category tag
  publishedAt DateTime @map("published_at")
  fetchedAt   DateTime @default(now()) @map("fetched_at")
  deletedAt   DateTime? @map("deleted_at")

  @@unique([feedId, externalId])
  @@index([feedId, publishedAt])
  @@index([publishedAt])
  @@index([deletedAt])
  @@map("news_articles")
}
