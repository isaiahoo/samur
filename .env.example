# ─── Database ───────────────────────────────────────────────────────────────
# Local dev: postgresql://samur:samur_dev@localhost:5432/samur?schema=public
# Docker:    postgresql://samur:CHANGE_ME@postgres:5432/samur?schema=public
DATABASE_URL="postgresql://samur:samur_dev@localhost:5432/samur?schema=public"
POSTGRES_USER="samur"
POSTGRES_PASSWORD="CHANGE_ME_STRONG_PASSWORD"
POSTGRES_DB="samur"

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── JWT ────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET="CHANGE_ME_MIN_32_CHARS"
JWT_EXPIRES_IN="7d"

# ─── Telegram Bot ───────────────────────────────────────────────────────────
# Get from @BotFather on Telegram: /newbot → copy the token
TG_BOT_TOKEN=""

# ─── VK Mini App ────────────────────────────────────────────────────────────
# Get from vk.com/apps?act=manage → your app → Settings
# App ID: shown on app info page
# Secret: Settings → "Защищённый ключ" (Protected key)
VK_APP_ID=""
VK_SECRET=""
VK_SERVICE_KEY=""

# ─── GreenSMS (phone verification via call) ────────────────────────────────
# Register at greensms.ru → get API token from dashboard
GREENSMS_TOKEN=""

# ─── Webhook API Key ───────────────────────────────────────────────────────
# Shared secret for SMS gateway and Meshtastic bridge
# Generate with: openssl rand -base64 32
WEBHOOK_API_KEY=""

# ─── Map Tiles ──────────────────────────────────────────────────────────────
# Tile provider: "maptiler" (default, needs API key) or "openfreemap" (free fallback)
TILE_PROVIDER="maptiler"
# Get from maptiler.com → Account → API Keys
# If empty, falls back to OpenFreeMap automatically
MAPTILER_API_KEY=""

# ─── Server ─────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV="development"
# Comma-separated allowed origins for CORS
CORS_ORIGINS="http://localhost:5173,http://localhost:5174"
LOG_LEVEL="debug"

# ─── SSL (production) ──────────────────────────────────────────────────────
# Domain for Let's Encrypt certificate
DOMAIN="samur.example.com"
CERTBOT_EMAIL="admin@example.com"

# ─── Monitoring (optional) ─────────────────────────────────────────────────
GRAFANA_PASSWORD="samur"
