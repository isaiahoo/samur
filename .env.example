# Database
DATABASE_URL="postgresql://samur:samur_dev@localhost:5432/samur?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="change-me-in-production-min-32-chars"
JWT_EXPIRES_IN="7d"

# Telegram Bot
TG_BOT_TOKEN="123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11"

# VK Mini App
VK_APP_ID="12345678"
VK_SECRET="your-vk-app-secret"

# SMS Gateway (FrontlineSMS or compatible)
SMS_GATEWAY_URL="http://localhost:4000/api/sms"
SMS_GATEWAY_API_KEY="your-sms-gateway-key"

# Meshtastic bridge
MESHTASTIC_SERIAL_PORT="/dev/ttyUSB0"
MESHTASTIC_API_URL="http://localhost:3000/api/v1"

# Server
PORT=3000
NODE_ENV="development"
CORS_ORIGINS="http://localhost:5173,http://localhost:5174"

# Logging
LOG_LEVEL="debug"
